{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "tasks": [
        {
            "label": "Create A New Component",
            "command": "bash",
            "args": ["./.vscode/new_comp.sh", "${input:componentName}"],
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Create A New Duck",
            "command": "bash",
            "args": ["./.vscode/new_duck.sh", "${input:duckName}"],
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ],
    "inputs": [
        {
            "id": "componentName",
            "type": "promptString",
            "description": "Enter the component name. Ex: Section",
            "default": ""
        },
        {
            "id": "duckName",
            "type": "promptString",
            "description": "Enter the duck name without suffix Duck in camel case. Ex: userInfo",
            "default": ""
        }
    ]
}
